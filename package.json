{
  "name": "react-boilerplate",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite --strictPort",
    "postinstall": "fenge install",
    "style": "fenge",
    "style:update": "fenge -u",
    "test": "tsc --noEmit"
  },
  "dependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/vite": "4.2.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/web": "0.0.346",
    "@vitejs/plugin-react": "6.0.1",
    "babel-plugin-react-compiler": "1.0.0",
    "daisyui": "5.5.19",
    "fenge": "0.13.2",
    "tailwindcss": "4.2.2",
    "typescript": "5.9.3",
    "vite": "8.0.8"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=22.18.0"
